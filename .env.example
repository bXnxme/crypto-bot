BINANCE_DEMO_API_KEY=your_demo_api_key
BINANCE_DEMO_API_SECRET=your_demo_api_secret

# Optional endpoint overrides
BINANCE_DEMO_REST_BASE_URL=https://demo-api.binance.com
BINANCE_DEMO_WS_BASE_URL=wss://demo-stream.binance.com

# Optional runner/state tuning
RUN_DEMO_GRID_STATE_FILE=data/run_demo_grid_state.json
RUN_DEMO_GRID_INTERVAL=15m
HEARTBEAT_SEC=10
# Safer defaults for open_orders diff handling
RUN_DEMO_GRID_OPEN_ORDERS_DIFF_GRACE_SEC=6
RUN_DEMO_GRID_OPEN_ORDERS_DIFF_STRATEGY_CANCEL=0
# Optional adapter guards
RUN_DEMO_GRID_ENABLE_LOT_RECOVERY=0
RUN_DEMO_GRID_BUY_SPEND_MIN_RATIO=0.20
# 1 = percent-based BUY spend is strict (full target or skip), 0 = allow degrade
RUN_DEMO_GRID_STRICT_SPEND_PCT=1

# Optional S3 backups for state/logs
RUN_DEMO_GRID_S3_ENABLED=0
RUN_DEMO_GRID_S3_ENDPOINT=https://s3.twcstorage.ru
RUN_DEMO_GRID_S3_REGION=ru-1
RUN_DEMO_GRID_S3_BUCKET=
RUN_DEMO_GRID_S3_ACCESS_KEY=
RUN_DEMO_GRID_S3_SECRET_KEY=
RUN_DEMO_GRID_S3_PREFIX=demo-grid
# 0 disables periodic log sync; state is still uploaded on flush/final when enabled
RUN_DEMO_GRID_S3_LOG_SYNC_SEC=0

# Telegram control bot (optional)
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric Telegram user IDs; empty = allow all
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_RUNNER_SERVICE=crypto-bot
TELEGRAM_POLL_TIMEOUT_SEC=25
TELEGRAM_CMD_TIMEOUT_SEC=20
TELEGRAM_LOG_LINES=25
TELEGRAM_DEBUG=0
# Sync command menu inside Telegram UI
TELEGRAM_SYNC_MENU_COMMANDS=1
TELEGRAM_SYNC_MENU_BUTTON=1
# commands | web_app | default
TELEGRAM_MENU_BUTTON_MODE=web_app
TELEGRAM_MENU_BUTTON_TEXT=Mini App

# Trade notifications (from logs/*_trades.jsonl)
TELEGRAM_NOTIFY_TRADES=1
# Comma-separated target chat IDs; empty -> use TELEGRAM_ALLOWED_USER_IDS
TELEGRAM_NOTIFY_CHAT_IDS=
# Optional explicit symbol (e.g. ETHUSDT); empty -> infer from state
TELEGRAM_NOTIFY_SYMBOL=
TELEGRAM_NOTIFY_POLL_SEC=2
# 0 = only new events after bot start, 1 = replay file from beginning
TELEGRAM_NOTIFY_FROM_BEGINNING=0
# Enrich notifications via Binance /api/v3/myTrades by order_id when fields are missing
TELEGRAM_NOTIFY_ENRICH_BINANCE=1
TELEGRAM_NOTIFY_ENRICH_RECV_WINDOW_MS=5000
TELEGRAM_NOTIFY_ENRICH_CACHE_MAX=2000

# Telegram Mini App
# Public HTTPS URL that Telegram will open inside WebApp button (/app command).
TELEGRAM_MINIAPP_URL=
# Mini app server bind (for src.telegram_miniapp)
TELEGRAM_MINIAPP_HOST=0.0.0.0
TELEGRAM_MINIAPP_PORT=8080
# Allow start/stop/restart actions from mini app
TELEGRAM_MINIAPP_ALLOW_RUNNER_CONTROL=1
# Expiration check for Telegram initData
TELEGRAM_MINIAPP_AUTH_MAX_AGE_SEC=86400
# Local browser debug only (no Telegram initData); keep 0 on server
TELEGRAM_MINIAPP_DEV_MODE=0
TELEGRAM_MINIAPP_DEV_USER_ID=
# Timezone used in Mini App for human-readable time and day-PnL boundaries
TELEGRAM_MINIAPP_TIMEZONE=Europe/Moscow
