diff --git a/run_sweep.sh b/run_sweep.sh
index 1111111..2222222 100755
--- a/run_sweep.sh
+++ b/run_sweep.sh
@@ -1,3 +1,62 @@
+### NOTE:
+# This patch adds generation of summary_sorted.tsv (sorted by pnl_total desc)
+# right after the sweep finishes and summary.tsv is created.
+
+# --- build a sorted summary file (same columns as summary.tsv) ---
+SUMMARY_SORTED="$SWEEP_DIR/summary_sorted.tsv"
+python - <<'PY'
+import os
+from decimal import Decimal
+
+sweep_dir = os.environ.get('SWEEP_DIR')
+if not sweep_dir:
+    raise SystemExit('SWEEP_DIR env var not set (run_sweep.sh must export SWEEP_DIR)')
+
+summary = os.path.join(sweep_dir, 'summary.tsv')
+out = os.path.join(sweep_dir, 'summary_sorted.tsv')
+
+with open(summary, 'r', encoding='utf-8') as f:
+    lines = [ln.rstrip('\n') for ln in f if ln.strip()]
+
+if not lines:
+    raise SystemExit('summary.tsv is empty')
+
+header, rows = lines[0], lines[1:]
+
+def key(row: str) -> Decimal:
+    # columns: be_trigger_mult, partial_frac, lock_atr_mult, result_line, diag3_line, reasons_line
+    cols = row.split('\t')
+    result_line = cols[3] if len(cols) > 3 else ''
+    marker = 'pnl_total='
+    i = result_line.find(marker)
+    if i == -1:
+        return Decimal('-Infinity')
+    j = i + len(marker)
+    k = result_line.find(' ', j)
+    if k == -1:
+        k = len(result_line)
+    try:
+        return Decimal(result_line[j:k])
+    except Exception:
+        return Decimal('-Infinity')
+
+rows_sorted = sorted(rows, key=key, reverse=True)
+
+with open(out, 'w', encoding='utf-8') as f:
+    f.write(header + '\n')
+    for r in rows_sorted:
+        f.write(r + '\n')
+
+print(f"Writing summary_sorted.tsv: {out}")
+PY
+
+echo
+echo "Top by pnl_total (from summary_sorted.tsv):"
+head -n 20 "$SUMMARY_SORTED"
+
diff --git a/run_sweep.sh b/run_sweep.sh
index 2222222..3333333 100755
--- a/run_sweep.sh
+++ b/run_sweep.sh
@@ -100,6 +159,14 @@ echo "DONE ✅"
 echo "Summary: $SWEEP_DIR/summary.tsv"
 echo "Logs dir: $SWEEP_DIR"
 
-echo
-echo "Top by pnl_total:"
-# (existing print logic here)
+echo
+echo "Top by pnl_total:"
+if [ -f "$SWEEP_DIR/summary_sorted.tsv" ]; then
+  head -n 20 "$SWEEP_DIR/summary_sorted.tsv"
+else
+  echo "WARN: $SWEEP_DIR/summary_sorted.tsv not found (generation step missing)"
+  head -n 20 "$SWEEP_DIR/summary.tsv"
+fi
